<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Tool VIP 2026</title>
  <style>
    body {
      text-align: center;
      font-family: Arial;
      margin-top: 120px;
      background: #f5f5f5;
    }
    h1 {
      color: #ff3b3b;
    }
    button {
      padding: 12px 25px;
      font-size: 16px;
      border: none;
      border-radius: 8px;
      background: #007bff;
      color: white;
      cursor: pointer;
    }
    #loading {
      display: none;
      margin-top: 20px;
      font-size: 18px;
    }
  </style>
</head>
<body>

<h1>🔥 Tool VIP miễn phí</h1>
<p>Bấm để mở tool ngay</p>

<button onclick="start()">MỞ TOOL</button>

<div id="loading">⏳ Đang tải tool... vui lòng chờ</div>

<script>
function start() {
  document.getElementById("loading").style.display = "block";

  setTimeout(() => {
    // 👉 DÁN LINK KIẾM TIỀN Ở ĐÂY
    window.location.href = "https://link-rut-gon-kiem-tien.com";
  }, 3000); // delay 3 giây cho giống thật
}
</script>

</body>
</html>
